<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - RemSolution</title>
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
            min-height: 100vh;
            display: flex;
            align-items: flex-start;
            justify-content: center;
            background: linear-gradient(135deg, #3f51b5 0%, #5c6bc0 50%, #7986cb 100%);
            padding: 48px 24px;
        }

        .manage-card {
            background: #fff;
            border-radius: 16px;
            box-shadow: 0 12px 40px rgba(0, 0, 0, .25);
            width: 100%;
            max-width: 560px;
            padding: 32px 36px;
        }

        .manage-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 8px;
        }

        .manage-header h1 {
            font-size: 20px;
            font-weight: 600;
            color: #212121;
        }

        .back-link {
            font-size: 14px;
            color: #3f51b5;
            text-decoration: none;
            font-weight: 500;
        }

        .back-link:hover { text-decoration: underline; }

        .manage-nav {
            display: flex;
            gap: 4px;
            border-bottom: 1px solid #e0e0e0;
            margin: 16px 0 24px;
        }

        .manage-nav a {
            padding: 10px 16px;
            font-size: 14px;
            font-weight: 500;
            color: #616161;
            text-decoration: none;
            border-bottom: 2px solid transparent;
            margin-bottom: -1px;
        }

        .manage-nav a:hover { color: #3f51b5; }

        .manage-nav a.active {
            color: #3f51b5;
            border-bottom-color: #3f51b5;
        }

        .form-group { margin-bottom: 18px; }

        .form-group label {
            display: block;
            font-size: 13px;
            font-weight: 600;
            color: #424242;
            margin-bottom: 6px;
        }

        .form-group input[type="email"],
        .form-group input[type="password"],
        .form-group input[type="text"],
        .form-group input[type="tel"] {
            width: 100%;
            padding: 12px 14px;
            border: 1px solid #c5cae9;
            border-radius: 8px;
            font-size: 15px;
            transition: border-color .15s, box-shadow .15s;
            outline: none;
        }

        .form-group input:focus {
            border-color: #3f51b5;
            box-shadow: 0 0 0 3px rgba(63, 81, 181, .15);
        }

        .form-group input[disabled], .form-group input[readonly] {
            background: #f5f5f5;
            color: #757575;
        }

        .field-hint {
            font-size: 12px;
            color: #9e9e9e;
            margin-top: 4px;
        }

        .btn-primary {
            padding: 12px 28px;
            background: #3f51b5;
            color: #fff;
            border: none;
            border-radius: 8px;
            font-size: 15px;
            font-weight: 600;
            cursor: pointer;
            transition: background .15s;
        }

        .btn-primary:hover { background: #303f9f; }

        .status-message {
            background: #e8f5e9;
            color: #2e7d32;
            border-radius: 8px;
            padding: 12px 16px;
            margin-bottom: 18px;
            font-size: 14px;
        }

        .validation-summary-errors, .field-validation-error {
            color: #c62828;
            font-size: 13px;
        }

        .validation-summary-errors {
            background: #fdecea;
            border-radius: 8px;
            padding: 12px 16px;
            margin-bottom: 18px;
        }

        .validation-summary-errors ul { list-style: none; }

        .field-validation-error { display: block; margin-top: 4px; }

        .validation-summary-valid { display: none; }
    </style>
</head>
<body>
    <div class="manage-card">
        <div class="manage-header">
            <h1>Account settings</h1>
            <a class="back-link" href="/">&larr; Back to app</a>
        </div>

        <nav class="manage-nav">
            <a asp-area="Identity" asp-page="/Account/Manage/Index"
               class="@(ViewData["ActivePage"] as string == "Index" ? "active" : "")">Profile</a>
            <a asp-area="Identity" asp-page="/Account/Manage/ChangePassword"
               class="@(ViewData["ActivePage"] as string == "ChangePassword" ? "active" : "")">Password</a>
        </nav>

        @RenderBody()
    </div>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
