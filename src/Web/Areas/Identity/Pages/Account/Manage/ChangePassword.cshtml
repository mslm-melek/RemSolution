@page
@model RemSolution.Web.Areas.Identity.Pages.Account.Manage.ChangePasswordModel
@{
    ViewData["Title"] = "Change password";
    ViewData["ActivePage"] = "ChangePassword";
    Layout = "~/Areas/Identity/Pages/Account/Manage/_ManageLayout.cshtml";
}

@if (Model.StatusMessage is not null)
{
    <div class="status-message">@Model.StatusMessage</div>
}

<form method="post">
    <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>

    <div class="form-group">
        <label asp-for="Input.OldPassword">Current password</label>
        <input asp-for="Input.OldPassword" autocomplete="current-password" placeholder="••••••••" />
        <span asp-validation-for="Input.OldPassword" class="field-validation-error"></span>
    </div>

    <div class="form-group">
        <label asp-for="Input.NewPassword">New password</label>
        <input asp-for="Input.NewPassword" autocomplete="new-password" placeholder="••••••••" />
        <span asp-validation-for="Input.NewPassword" class="field-validation-error"></span>
    </div>

    <div class="form-group">
        <label asp-for="Input.ConfirmPassword">Confirm new password</label>
        <input asp-for="Input.ConfirmPassword" autocomplete="new-password" placeholder="••••••••" />
        <span asp-validation-for="Input.ConfirmPassword" class="field-validation-error"></span>
    </div>

    <button type="submit" class="btn-primary">Update password</button>
</form>

@section Scripts {
    <script src="~/Identity/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/Identity/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/Identity/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
}
