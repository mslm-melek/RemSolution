@page
@model RemSolution.Web.Areas.Identity.Pages.Account.LoginModel
@{
    ViewData["Title"] = "Sign in";
    Layout = "~/Areas/Identity/Pages/Account/_AuthLayout.cshtml";
}

<p class="auth-subtitle">Sign in to your account</p>

<form method="post">
    <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>

    <div class="form-group">
        <label asp-for="Input.Email">Email</label>
        <input asp-for="Input.Email" autocomplete="username" autofocus placeholder="you@example.com" />
        <span asp-validation-for="Input.Email" class="field-validation-error"></span>
    </div>

    <div class="form-group">
        <label asp-for="Input.Password">Password</label>
        <input asp-for="Input.Password" autocomplete="current-password" placeholder="••••••••" />
        <span asp-validation-for="Input.Password" class="field-validation-error"></span>
    </div>

    <div class="checkbox-row">
        <input asp-for="Input.RememberMe" />
        <label asp-for="Input.RememberMe" style="margin: 0; font-weight: 400;">Remember me</label>
    </div>

    <button type="submit" class="btn-primary">Sign in</button>

    <div class="auth-links">
        <a asp-page="./ForgotPassword">Forgot your password?</a>
        <span>Don't have an account? <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl">Create one</a></span>
    </div>
</form>

@section Scripts {
    <script src="~/Identity/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/Identity/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/Identity/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
}
