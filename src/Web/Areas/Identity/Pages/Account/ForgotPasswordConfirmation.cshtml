@page
@model RemSolution.Web.Areas.Identity.Pages.Account.ForgotPasswordConfirmationModel
@{
    ViewData["Title"] = "Check your email";
    Layout = "~/Areas/Identity/Pages/Account/_AuthLayout.cshtml";
}

<p class="auth-subtitle">Password reset requested</p>

<p class="auth-message">
    If an account exists for that email address, a password reset link has been sent.
    Please check your inbox.
</p>

@if (Model.DevResetLink is not null)
{
    <div class="dev-note">
        <strong>Development only</strong> — no email server is configured, use this link:
        <a href="@Model.DevResetLink">Reset password</a>
    </div>
}

<div class="auth-links">
    <a asp-page="./Login">Back to sign in</a>
</div>
